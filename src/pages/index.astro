<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BabyZey Boosting</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&display=swap');

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            /* Replace with a dark Valorant wallpaper */
            background: url('https://images.unsplash.com/photo-1542751371-adc38448a05e?q=80&w=2070&auto=format&fit=crop') no-repeat center center fixed;
            background-size: cover;
            height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: white;
        }

        /* Dark overlay to match the template's mood */
        .overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(10, 10, 15, 0.7);
            z-index: -1;
        }

        .header-section {
            text-align: center;
            margin-bottom: 30px;
        }

        .header-section h1 {
            font-size: 2.5rem;
            font-weight: 400;
            letter-spacing: 1px;
            margin-bottom: 10px;
        }

        .header-section p {
            font-size: 0.85rem;
            letter-spacing: 2px;
            color: #d1d5db;
            text-transform: uppercase;
        }

        /* Glassmorphism Panel */
        .glass-panel {
            background: rgba(40, 42, 54, 0.4);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            padding: 50px;
            width: 90%;
            max-width: 600px;
        }

        .grid-container {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 40px 20px;
            text-align: center;
        }

        .service-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            cursor: pointer;
            transition: transform 0.2s ease, color 0.2s ease;
            text-decoration: none;
            color: white;
        }

        .service-item:hover {
            transform: translateY(-5px);
            color: #ff4655; /* Valorant Red */
        }

        .service-item i {
            font-size: 2rem;
            margin-bottom: 15px;
            font-weight: 300;
        }

        .service-item span {
            font-size: 0.9rem;
            font-weight: 300;
        }

        .social-footer {
            margin-top: 40px;
            display: flex;
            gap: 25px;
        }

        .social-footer a {
            color: white;
            font-size: 1.2rem;
            transition: color 0.2s ease;
        }

        .social-footer a:hover {
            color: #ff4655;
        }

        /* Responsive Design for Mobile */
        @media (max-width: 600px) {
            .grid-container {
                grid-template-columns: repeat(2, 1fr);
            }
            .glass-panel {
                padding: 30px;
            }
        }
    </style>
</head>
<body>

    <div class="overlay"></div>

    <div class="header-section">
        <h1>BabyZey Boosting</h1>
        <p>Choose A Category</p>
    </div>

    <div class="glass-panel">
        <div class="grid-container">
            <a href="#" class="service-item">
                <i class="fa-solid fa-arrow-trend-up"></i>
                <span>Rank Boost</span>
            </a>
            <a href="#" class="service-item">
                <i class="fa-solid fa-gamepad"></i>
                <span>Placements</span>
            </a>
            <a href="#" class="service-item">
                <i class="fa-solid fa-trophy"></i>
                <span>Win Boost</span>
            </a>
            <a href="#" class="service-item">
                <i class="fa-solid fa-user-group"></i>
                <span>Duo Queue</span>
            </a>
            <a href="#" class="service-item">
                <i class="fa-solid fa-chalkboard-user"></i>
                <span>Coaching</span>
            </a>
            <a href="#" class="service-item">
                <i class="fa-solid fa-users"></i>
                <span>Accounts</span>
            </a>
        </div>
    </div>

    <div class="social-footer">
        <a href="#"><i class="fa-brands fa-instagram"></i></a>
        <a href="#"><i class="fa-brands fa-facebook-f"></i></a>
        <a href="#"><i class="fa-brands fa-twitter"></i></a>
    </div>

</body>
</html>
